---
import { getLangFromUrl, alternatePaths } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const { ko, en } = alternatePaths(Astro.url);
const target = lang === 'en' ? ko : en;
const label = lang === 'en' ? '한국어' : 'EN';
---

<a
  href={target}
  class="grid h-8 min-w-8 place-items-center rounded-md px-1.5 text-xs font-medium text-neutral-500 transition-colors hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100"
  aria-label="Switch language"
>
  {label}
</a>
