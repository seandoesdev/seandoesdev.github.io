---
import { getLangFromUrl, alternatePaths } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const { ko, en } = alternatePaths(Astro.url);
const target = lang === 'en' ? ko : en;
const label = lang === 'en' ? 'KO' : 'EN';
---

<a
  href={target}
  class="grid h-9 min-w-9 place-items-center rounded-md px-2 text-xs font-semibold text-neutral-600 transition hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-800"
  aria-label="Switch language"
>
  {label}
</a>
