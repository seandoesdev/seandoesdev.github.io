---
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';
import type { UIKey } from '../i18n/ui';
import { SITE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
import LangToggle from './LangToggle.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const items: { href: string; key: UIKey }[] = [
  { href: '/', key: 'nav.home' },
  { href: '/blog', key: 'nav.blog' },
  { href: '/projects', key: 'nav.projects' },
  { href: '/tags', key: 'nav.tags' },
  { href: '/about', key: 'nav.about' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const home = localizePath('/', lang).replace(/\/$/, '') || '/';
function active(href: string): boolean {
  const full = localizePath(href, lang).replace(/\/$/, '') || '/';
  return href === '/'
    ? pathname === home
    : pathname === full || pathname.startsWith(`${full}/`);
}
---

{/* 모바일: 상단 바 */}
<div class="sticky top-0 z-40 -mx-6 flex flex-wrap items-center justify-between gap-x-4 gap-y-2 border-b border-stone-200 bg-[#faf8f4]/95 px-6 py-4 backdrop-blur sm:-mx-8 sm:px-8 lg:hidden dark:border-stone-800 dark:bg-[#191714]/95">
  <a href={localizePath('/', lang)} class="font-serif text-xl font-semibold tracking-tight">{SITE.title}<span style="color: var(--accent)">.</span></a>
  <div class="flex flex-wrap items-center justify-end gap-x-4 gap-y-1 text-[15px]">
    {
      items.filter((i) => i.href !== '/').map((item) => (
        <a
          href={localizePath(item.href, lang)}
          class:list={['transition-colors', active(item.href) ? 'text-stone-900 dark:text-stone-100' : 'text-stone-500 dark:text-stone-400']}
        >
          {t(item.key)}
        </a>
      ))
    }
    <span class="flex items-center gap-1"><LangToggle /><ThemeToggle /></span>
  </div>
</div>

{/* 데스크톱: 좌측 고정 사이드바 */}
<aside class="hidden lg:sticky lg:top-0 lg:flex lg:h-dvh lg:flex-col lg:py-16">
  <a href={localizePath('/', lang)} class="font-serif text-2xl font-semibold tracking-tight">{SITE.title}<span style="color: var(--accent)">.</span></a>
  <p class="mt-3 max-w-[12rem] text-sm leading-relaxed text-stone-500 dark:text-stone-400">{t('site.tagline')}</p>
  <nav class="mt-10 flex flex-col items-start gap-y-2 text-[15px]">
    {
      items.map((item) => (
        <a
          href={localizePath(item.href, lang)}
          class:list={[
            'transition-colors',
            active(item.href)
              ? 'font-medium text-stone-900 dark:text-stone-100'
              : 'text-stone-500 hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100',
          ]}
        >
          {t(item.key)}
        </a>
      ))
    }
  </nav>
  <div class="mt-auto flex items-center gap-x-4 pt-8 text-sm text-stone-500 dark:text-stone-400">
    <a href="https://github.com/seandoesdev" class="transition-colors hover:text-stone-900 dark:hover:text-stone-100">GitHub</a>
    <a href="/rss.xml" class="transition-colors hover:text-stone-900 dark:hover:text-stone-100">RSS</a>
    <span class="ml-auto flex items-center gap-1"><LangToggle /><ThemeToggle /></span>
  </div>
</aside>
