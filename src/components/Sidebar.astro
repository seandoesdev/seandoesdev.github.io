---
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';
import type { UIKey } from '../i18n/ui';
import { SITE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
import LangToggle from './LangToggle.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const items: { href: string; key: UIKey }[] = [
  { href: '/', key: 'nav.home' },
  { href: '/blog', key: 'nav.blog' },
  { href: '/portfolio', key: 'nav.projects' },
  { href: '/tags', key: 'nav.tags' },
  { href: '/about', key: 'nav.about' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const home = localizePath('/', lang).replace(/\/$/, '') || '/';
function active(href: string): boolean {
  const full = localizePath(href, lang).replace(/\/$/, '') || '/';
  return href === '/'
    ? pathname === home
    : pathname === full || pathname.startsWith(`${full}/`);
}
---

{/* 모바일: 상단 바 */}
<div class="sticky top-0 z-40 -mx-6 flex flex-wrap items-center justify-between gap-x-4 gap-y-2 border-b border-neutral-200 bg-white/95 px-6 py-4 backdrop-blur sm:-mx-8 sm:px-8 lg:hidden dark:border-neutral-800 dark:bg-neutral-950/95">
  <a href={localizePath('/', lang)} class="text-lg font-bold tracking-tight">{SITE.title}</a>
  <div class="flex flex-wrap items-center justify-end gap-x-4 gap-y-1 text-[15px]">
    {
      items.filter((i) => i.href !== '/').map((item) => (
        <a
          href={localizePath(item.href, lang)}
          class:list={['transition-colors', active(item.href) ? '[color:var(--accent)]' : 'text-neutral-500 dark:text-neutral-400']}
        >
          {t(item.key)}
        </a>
      ))
    }
    <span class="flex items-center gap-1"><LangToggle /><ThemeToggle /></span>
  </div>
</div>

{/* 데스크톱: 좌측 사이드바 */}
<aside class="hidden lg:sticky lg:top-0 lg:flex lg:h-dvh lg:flex-col lg:py-16 lg:pr-8">
  <a href={localizePath('/', lang)} class="text-xl font-bold tracking-tight">{SITE.title}</a>
  <p class="mt-1 text-sm text-neutral-400 dark:text-neutral-500">{t('site.role')}</p>
  <nav class="mt-10 flex flex-col items-start gap-y-2.5 text-[15px]">
    {
      items.map((item) => {
        const on = active(item.href);
        return (
          <a
            href={localizePath(item.href, lang)}
            class:list={[
              'flex items-center gap-1.5 transition-colors',
              on ? 'font-medium [color:var(--accent)]' : 'text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100',
            ]}
          >
            <span class="w-2 [color:var(--accent)]">{on ? '›' : ''}</span>
            {t(item.key)}
          </a>
        );
      })
    }
  </nav>
  <div class="mt-auto flex items-center gap-2 pt-8">
    <LangToggle />
    <ThemeToggle />
  </div>
</aside>
