---
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';
import type { UIKey } from '../i18n/ui';
import { SITE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
import LangToggle from './LangToggle.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const items: { href: string; key: UIKey }[] = [
  { href: '/blog', key: 'nav.blog' },
  { href: '/projects', key: 'nav.projects' },
  { href: '/tags', key: 'nav.tags' },
  { href: '/about', key: 'nav.about' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
function active(href: string): boolean {
  const full = localizePath(href, lang).replace(/\/$/, '') || '/';
  return pathname === full || pathname.startsWith(`${full}/`);
}
---

<header class="sticky top-0 z-40 border-b border-stone-200 bg-[#faf8f4]/95 dark:border-stone-800 dark:bg-[#191714]/95">
  <div class="mx-auto flex max-w-3xl flex-wrap items-center justify-between gap-x-6 gap-y-2 px-6 py-4 sm:px-8">
    <a href={localizePath('/', lang)} class="font-serif text-xl font-semibold tracking-tight">
      {SITE.title}<span style="color: var(--accent)">.</span>
    </a>
    <nav class="flex items-center gap-x-5 text-[15px]">
      {
        items.map((item) => (
          <a
            href={localizePath(item.href, lang)}
            class:list={[
              'transition-colors',
              active(item.href)
                ? 'text-stone-900 dark:text-stone-100'
                : 'text-stone-500 hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100',
            ]}
          >
            {t(item.key)}
          </a>
        ))
      }
      <span class="ml-1 flex items-center gap-1">
        <LangToggle />
        <ThemeToggle />
      </span>
    </nav>
  </div>
</header>
