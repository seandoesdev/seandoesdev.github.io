---
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';
import type { UIKey } from '../i18n/ui';
import { SITE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
import LangToggle from './LangToggle.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const items: { href: string; key: UIKey }[] = [
  { href: '/', key: 'nav.home' },
  { href: '/blog', key: 'nav.blog' },
  { href: '/projects', key: 'nav.projects' },
  { href: '/tags', key: 'nav.tags' },
  { href: '/about', key: 'nav.about' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const home = localizePath('/', lang).replace(/\/$/, '') || '/';
function active(href: string): boolean {
  const full = localizePath(href, lang).replace(/\/$/, '') || '/';
  return href === '/'
    ? pathname === home
    : pathname === full || pathname.startsWith(`${full}/`);
}
---

<header class="sticky top-0 z-40 border-b border-neutral-200/70 bg-white/70 backdrop-blur-md dark:border-neutral-800/70 dark:bg-neutral-950/70">
  <div class="mx-auto flex max-w-2xl flex-wrap items-center justify-between gap-x-4 gap-y-2 px-5 py-3">
    <a href={localizePath('/', lang)} class="flex items-center gap-2">
      <span class="grid size-7 place-items-center rounded-lg bg-gradient-to-br from-indigo-500 to-indigo-700 text-sm font-bold text-white shadow-sm">s</span>
      <span class="text-base font-bold tracking-tight">{SITE.title}</span>
    </a>
    <nav class="flex items-center gap-0.5 text-sm">
      {
        items.map((item) => (
          <a
            href={localizePath(item.href, lang)}
            class:list={[
              'rounded-md px-2.5 py-1.5 transition',
              active(item.href)
                ? 'font-semibold text-indigo-600 dark:text-indigo-400'
                : 'text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100',
            ]}
          >
            {t(item.key)}
          </a>
        ))
      }
      <span class="mx-1 h-4 w-px bg-neutral-200 dark:bg-neutral-700" aria-hidden="true"></span>
      <LangToggle />
      <ThemeToggle />
    </nav>
  </div>
</header>
