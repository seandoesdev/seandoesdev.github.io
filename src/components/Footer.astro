---
import { SITE } from '../consts';
const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-200 py-8 text-sm text-neutral-500 dark:border-neutral-800 dark:text-neutral-400">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <p>© {year} {SITE.author}</p>
    <div class="flex items-center gap-4">
      <a href="/rss.xml" class="hover:text-neutral-900 dark:hover:text-neutral-100">RSS</a>
      <a href="https://github.com/seandoesdev" class="hover:text-neutral-900 dark:hover:text-neutral-100">GitHub</a>
    </div>
  </div>
</footer>
