---
import { SITE } from '../consts';
const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-200 dark:border-neutral-800">
  <div class="mx-auto flex max-w-2xl flex-wrap items-center justify-between gap-3 px-5 py-8 text-sm text-neutral-500 dark:text-neutral-400">
    <p>© {year} {SITE.author}</p>
    <div class="flex items-center gap-4">
      <a href="/rss.xml" class="transition hover:text-indigo-600 dark:hover:text-indigo-400">RSS</a>
      <a href="https://github.com/seandoesdev" class="transition hover:text-indigo-600 dark:hover:text-indigo-400">GitHub</a>
    </div>
  </div>
</footer>
