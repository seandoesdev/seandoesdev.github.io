---
import { SITE } from '../consts';
import { getLangFromUrl } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const year = new Date().getFullYear();
const madeWith = lang === 'en' ? 'Made with care in Seoul' : '서울에서 정성껏 만듭니다';
---

<footer class="flex flex-wrap items-center justify-between gap-3 border-t border-stone-200 py-8 text-sm text-stone-500 dark:border-stone-800 dark:text-stone-400">
  <p>© {year} {SITE.author} · <span class="text-stone-400 dark:text-stone-500">{madeWith}</span></p>
  <div class="flex items-center gap-4">
    <a href="/rss.xml" class="transition-colors hover:text-stone-900 dark:hover:text-stone-100">RSS</a>
    <a href="https://github.com/seandoesdev" class="transition-colors hover:text-stone-900 dark:hover:text-stone-100">GitHub</a>
  </div>
</footer>
