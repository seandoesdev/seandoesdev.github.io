---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, postHref } from '../../i18n/utils';
import { getPosts } from '../../lib/content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const dateLocale = lang === 'en' ? 'en-US' : 'ko-KR';
const posts = await getPosts(lang);
---

<BaseLayout title={t('blog.title')}>
  <h1 class="text-2xl font-bold tracking-tight">{t('blog.title')}</h1>
  <ul class="mt-8 divide-y divide-neutral-200 dark:divide-neutral-800">
    {posts.length === 0 && <li class="py-6 text-neutral-500">{t('blog.empty')}</li>}
    {
      posts.map((post) => (
        <li>
          <a href={postHref(post.id, lang)} class="group block py-5">
            <div class="flex items-baseline justify-between gap-4">
              <h2 class="font-semibold text-neutral-900 transition-colors group-hover:[color:var(--accent)] dark:text-neutral-100">{post.data.title}</h2>
              <time class="shrink-0 text-sm tabular-nums text-neutral-400 dark:text-neutral-500" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString(dateLocale)}
              </time>
            </div>
            <p class="mt-1 leading-relaxed text-neutral-500 dark:text-neutral-400">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm text-neutral-400 dark:text-neutral-500">
                {post.data.tags.map((tag) => (
                  <span>#{tag}</span>
                ))}
              </div>
            )}
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
