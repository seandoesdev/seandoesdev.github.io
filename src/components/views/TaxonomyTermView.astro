---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, postHref, localizePath } from '../../i18n/utils';
import type { Post } from '../../lib/content';
import type { TaxonomyKind } from '../../lib/taxonomy';

interface Props {
  kind: TaxonomyKind;
  term: string;
  posts: Post[];
}

const { kind, term, posts } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const dateLocale = lang === 'en' ? 'en-US' : 'ko-KR';
const prefix = kind === 'tags' ? t('tags.postsIn') : t('categories.postsIn');
const label = kind === 'tags' ? `#${term}` : term;
const backHref = localizePath(kind === 'tags' ? '/tags' : '/categories', lang);
---

<BaseLayout title={`${prefix}${label}`}>
  <h1 class="text-2xl font-bold tracking-tight">{prefix}<span class="text-neutral-500">{label}</span></h1>
  <ul class="mt-6 space-y-6">
    {posts.length === 0 && <li class="text-neutral-500">{t('blog.empty')}</li>}
    {
      posts.map((post) => (
        <li>
          <a href={postHref(post.id, lang)} class="group block">
            <div class="flex items-baseline justify-between gap-4">
              <h2 class="font-medium group-hover:underline">{post.data.title}</h2>
              <time class="shrink-0 text-sm tabular-nums text-neutral-400" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString(dateLocale)}
              </time>
            </div>
            <p class="mt-1 line-clamp-2 text-sm text-neutral-500 dark:text-neutral-400">{post.data.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
  <div class="mt-10">
    <a href={backHref} class="text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-100">{t('post.back')}</a>
  </div>
</BaseLayout>
