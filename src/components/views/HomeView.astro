---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, postHref, localizePath } from '../../i18n/utils';
import { getPosts } from '../../lib/content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const dateLocale = lang === 'en' ? 'en-US' : 'ko-KR';
const posts = (await getPosts(lang)).slice(0, 6);

const quickLinks = [
  { href: '/blog', key: 'nav.blog' as const },
  { href: '/projects', key: 'nav.projects' as const },
  { href: '/about', key: 'nav.about' as const },
];
---

<BaseLayout>
  <section class="pt-2 pb-4">
    <h1 class="font-serif text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">{t('home.greeting')}</h1>
    <div class="mt-6 max-w-xl space-y-4 text-lg leading-relaxed text-stone-600 dark:text-stone-300">
      <p>{t('home.intro')}</p>
      <p class="text-stone-500 dark:text-stone-400">{t('home.intro2')}</p>
    </div>
    <nav class="mt-7 flex flex-wrap items-center gap-x-5 gap-y-2 text-[15px]">
      {
        quickLinks.map((l) => (
          <a
            href={localizePath(l.href, lang)}
            class="text-stone-700 underline decoration-stone-300 underline-offset-4 transition-colors hover:decoration-[var(--accent)] hover:[color:var(--accent)] dark:text-stone-300 dark:decoration-stone-600"
          >
            {t(l.key)}
          </a>
        ))
      }
      <a
        href="/rss.xml"
        class="text-stone-700 underline decoration-stone-300 underline-offset-4 transition-colors hover:decoration-[var(--accent)] hover:[color:var(--accent)] dark:text-stone-300 dark:decoration-stone-600"
      >RSS</a>
    </nav>
  </section>

  <section class="mt-16">
    <div class="flex items-baseline justify-between border-b border-stone-200 pb-2 dark:border-stone-800">
      <h2 class="font-serif text-lg font-semibold">{t('home.recent')}</h2>
      <a href={localizePath('/blog', lang)} class="text-sm text-stone-500 transition-colors hover:[color:var(--accent)]">{t('home.viewAll')}</a>
    </div>
    <ul class="divide-y divide-stone-200 dark:divide-stone-800">
      {posts.length === 0 && <li class="py-5 text-stone-500">{t('blog.empty')}</li>}
      {
        posts.map((post) => (
          <li>
            <a href={postHref(post.id, lang)} class="group block py-4">
              <div class="flex items-baseline justify-between gap-4">
                <h3 class="font-medium text-stone-800 transition-colors group-hover:[color:var(--accent)] dark:text-stone-200">{post.data.title}</h3>
                <time class="shrink-0 text-sm tabular-nums text-stone-400" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString(dateLocale)}
                </time>
              </div>
              <p class="mt-1 line-clamp-1 text-[15px] text-stone-500 dark:text-stone-400">{post.data.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
