---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, postHref, localizePath } from '../../i18n/utils';
import { getPosts } from '../../lib/content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const dateLocale = lang === 'en' ? 'en-US' : 'ko-KR';
const posts = (await getPosts(lang)).slice(0, 6);
---

<BaseLayout>
  <section>
    <h1 class="font-serif text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">{t('home.greeting')}</h1>
    <div class="mt-6 max-w-2xl space-y-4 text-lg leading-relaxed text-stone-600 dark:text-stone-300">
      <p>{t('home.intro')}</p>
      <p class="text-stone-500 dark:text-stone-400">{t('home.intro2')}</p>
    </div>
  </section>

  <section class="mt-16">
    <div class="flex items-baseline justify-between border-b border-stone-200 pb-2 dark:border-stone-800">
      <h2 class="font-serif text-lg font-semibold">{t('home.recent')}</h2>
      <a href={localizePath('/blog', lang)} class="text-sm text-stone-500 transition-colors hover:[color:var(--accent)]">{t('home.viewAll')}</a>
    </div>
    <ul class="divide-y divide-stone-200 dark:divide-stone-800">
      {posts.length === 0 && <li class="py-5 text-stone-500">{t('blog.empty')}</li>}
      {
        posts.map((post) => (
          <li>
            <a href={postHref(post.id, lang)} class="group flex flex-col gap-1 py-4 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
              <span class="font-medium text-stone-800 transition-colors group-hover:[color:var(--accent)] dark:text-stone-200">{post.data.title}</span>
              <time class="shrink-0 text-sm tabular-nums text-stone-400" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString(dateLocale)}
              </time>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
