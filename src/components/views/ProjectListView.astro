---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getProjects } from '../../lib/content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const projects = await getProjects(lang);
---

<BaseLayout title={t('projects.title')}>
  <h1 class="text-2xl font-bold tracking-tight">{t('projects.title')}</h1>
  <p class="mt-2 text-neutral-500 dark:text-neutral-400">{t('projects.note')}</p>
  <ul class="mt-8 divide-y divide-neutral-200 dark:divide-neutral-800">
    {projects.length === 0 && <li class="py-6 text-neutral-500">{t('projects.empty')}</li>}
    {
      projects.map((project) => (
        <li class="py-5">
          <div class="flex items-baseline justify-between gap-4">
            <h2 class="font-semibold text-neutral-900 dark:text-neutral-100">{project.data.title}</h2>
            <div class="flex shrink-0 gap-4 text-sm text-neutral-500 dark:text-neutral-400">
              {project.data.repo && <a href={project.data.repo} class="transition-colors hover:[color:var(--accent)]">{t('projects.code')}</a>}
              {project.data.demo && <a href={project.data.demo} class="transition-colors hover:[color:var(--accent)]">{t('projects.demo')}</a>}
            </div>
          </div>
          <p class="mt-1 leading-relaxed text-neutral-500 dark:text-neutral-400">{project.data.description}</p>
          {project.data.tech.length > 0 && (
            <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm text-neutral-400 dark:text-neutral-500">
              {project.data.tech.map((tech) => (
                <span>{tech}</span>
              ))}
            </div>
          )}
        </li>
      ))
    }
  </ul>
</BaseLayout>
