---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// NOTE: 아래 내용은 편집용 템플릿입니다. 실제 이력/링크로 자유롭게 바꾸세요.
---

<BaseLayout title={t('about.title')}>
  <h1 class="text-2xl font-bold tracking-tight">{t('about.title')}</h1>
  <div class="prose prose-neutral mt-6 max-w-none dark:prose-invert">
    {
      lang === 'en' ? (
        <Fragment>
          <p>Hi, I'm <strong>Sean</strong>. I build things for the web and write about what I learn along the way.</p>
          <h2>What I do</h2>
          <ul>
            <li>Frontend & full-stack development</li>
            <li>Writing about tools, patterns, and small experiments</li>
          </ul>
          <h2>Skills</h2>
          <p>TypeScript · Astro · React · Node.js <em>(edit me)</em></p>
          <h2>Contact</h2>
          <ul>
            <li>GitHub: <a href="https://github.com/seandoesdev">@seandoesdev</a></li>
            <li>Email: <em>you@example.com (edit me)</em></li>
          </ul>
        </Fragment>
      ) : (
        <Fragment>
          <p>안녕하세요, <strong>Sean</strong>입니다. 웹을 만들고, 배운 것을 기록합니다.</p>
          <h2>하는 일</h2>
          <ul>
            <li>프론트엔드 · 풀스택 개발</li>
            <li>도구·패턴·작은 실험에 대한 글쓰기</li>
          </ul>
          <h2>기술</h2>
          <p>TypeScript · Astro · React · Node.js <em>(수정하세요)</em></p>
          <h2>연락처</h2>
          <ul>
            <li>GitHub: <a href="https://github.com/seandoesdev">@seandoesdev</a></li>
            <li>이메일: <em>you@example.com (수정하세요)</em></li>
          </ul>
        </Fragment>
      )
    }
  </div>
</BaseLayout>
