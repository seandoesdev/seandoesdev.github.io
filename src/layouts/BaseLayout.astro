---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const { title, description, image, article } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} image={image} article={article} />
  </head>
  <body class="flex min-h-dvh flex-col bg-[#faf8f4] text-stone-800 antialiased dark:bg-[#191714] dark:text-stone-200">
    <Header />
    <main class="mx-auto w-full max-w-3xl flex-1 px-6 py-14 sm:px-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>
