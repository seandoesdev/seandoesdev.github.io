---
import BaseHead from '../components/BaseHead.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const { title, description, image, article } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} image={image} article={article} />
  </head>
  <body class="bg-[#faf8f4] text-stone-800 antialiased dark:bg-[#191714] dark:text-stone-200">
    <div class="mx-auto max-w-5xl px-6 sm:px-8 lg:grid lg:grid-cols-[12rem_minmax(0,1fr)] lg:gap-x-16">
      <Sidebar />
      <div class="flex min-h-dvh flex-col">
        <main class="flex-1 py-10 lg:py-16">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
