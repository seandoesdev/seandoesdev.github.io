---
import BaseHead from '../components/BaseHead.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const { title, description, image, article } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} image={image} article={article} />
  </head>
  <body class="bg-white text-neutral-900 antialiased dark:bg-neutral-950 dark:text-neutral-100">
    <div class="mx-auto max-w-5xl px-6 sm:px-8 lg:grid lg:grid-cols-[13rem_minmax(0,1fr)]">
      <Sidebar />
      <div class="flex min-h-dvh flex-col lg:border-l lg:border-neutral-200 lg:pl-12 dark:lg:border-neutral-800">
        <main class="flex-1 py-10 lg:py-16">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
