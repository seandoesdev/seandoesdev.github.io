---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const { title, description, image, article } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} image={image} article={article} />
  </head>
  <body class="flex min-h-dvh flex-col bg-white text-neutral-900 antialiased dark:bg-neutral-950 dark:text-neutral-100">
    <Header />
    <main class="mx-auto w-full max-w-2xl flex-1 px-5 py-12">
      <slot />
    </main>
    <Footer />
  </body>
</html>
